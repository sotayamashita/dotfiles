# =============================================================================
# Dotfiles Symlink Configuration
# =============================================================================
# Syntax: gitignore-like glob patterns
# - Lines starting with # are comments
# - Empty lines are ignored
# - * matches any characters except /
# - ** matches any directory depth
# - !pattern excludes files matched by previous patterns
# =============================================================================

# Zed
.config/zed/settings.json

# Coding Agent
.agents/AGENTS.md

# Claude Code
.claude/**
!.claude/README.md

# OpenAI Codex
.codex/config.toml
.codex/AGENTS.md
.codex/prompts/*.md

# Fish shell
.config/fish/**/*.fish

# Ghosty
.config/ghostty/config

# Yazi
.config/yazi/yazi.toml

# Starship prompt
.config/starship.toml

# Mise (runtime version manager)
.config/mise/config.toml

# JankyBorders
.config/borders/bordersrc

# Git configuration
.gitconfig
.gitconfig.*
.gitignore.global
.gitattributes.global
# Ignore it since it is only for this repository
!.gitignore.local

# Homebrew
Brewfile

# pnpm
.config/pnpm/rc

# npm
.npmrc

# uv (Python package installer)
.config/uv/uv.toml

# Bun
bunfig.toml
