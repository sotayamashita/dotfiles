{
  "filters": {
    "comments": true
  },
  "rules": {
    "prh": {
      "rulePaths": ["./prh.yml"]
    },
    "preset-ja-technical-writing": {
      "sentence-length": {
        "max": 60
      },
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "である",
        "preferInList": "である",
        "strict": false
      }
    },
    "@textlint-ja/preset-ai-writing": {
      "ai-tech-writing-guideline": false
    }
  }
}
