#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: scan staged files for committed secrets with secretlint.
# Deterministic gate covering Claude Code, Codex, and manual commits; pairs with
# the "never commit or expose secrets" default in .agents/AGENTS.md.
# Skips when secretlint is not installed or nothing is staged.
# Bypass once with: git commit --no-verify

# Make Homebrew and mise-managed Node reachable regardless of launch environment.
PATH="/opt/homebrew/bin:${HOME}/.local/share/mise/shims:${PATH}"
export PATH

# Nothing staged -> nothing to scan.
if [ -z "$(git diff --cached --name-only --diff-filter=ACMR)" ]; then
    exit 0
fi

# Resolve the repo-local secretlint workspace via this hook's symlink target.
src="${BASH_SOURCE[0]}"
if [ -L "${src}" ]; then
    src="$(readlink "${src}")"
fi
hook_dir="$(cd "$(dirname "${src}")" && pwd)"
repo_root="$(cd "${hook_dir}/.." && pwd)"
secretlint_dir="${repo_root}/tools/secretlint"
secretlint_bin="${secretlint_dir}/node_modules/.bin/secretlint"

# Not installed yet -> guide the user, but do not block the commit.
if [ ! -x "${secretlint_bin}" ]; then
    echo "secretlint not installed. Run: sfw pnpm -C ${secretlint_dir} install" >&2
    exit 0
fi

# Scan staged paths as literal inputs (--no-glob), NUL-delimited for safety.
if git diff --cached --name-only --diff-filter=ACMR -z |
    xargs -0 "${secretlint_bin}" \
        --secretlintrc "${secretlint_dir}/.secretlintrc.json" --no-glob; then
    exit 0
fi

{
    echo "secretlint found credentials in staged files. Remove them, restage, then commit again."
    echo "Bypass once with: git commit --no-verify"
} >&2
exit 1
