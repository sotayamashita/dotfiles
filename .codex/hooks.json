{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/sfw-gate.sh",
            "statusMessage": "Checking Bash command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/sfw-post-edit.sh",
            "statusMessage": "Checking dependency manifest edits"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/textlint-md.sh",
            "statusMessage": "Checking Japanese Markdown"
          }
        ]
      }
    ]
  }
}
